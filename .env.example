# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/dbname

# Auth
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Auth mode: jwt | basic | both
AUTH_MODE=jwt

# Server
HOST=0.0.0.0
PORT=8000

# API mode: rest | graphql | both
API_MODE=both

# Explorer UI
ENABLE_EXPLORER=true
# Pre-fill login form credentials (leave empty to require manual login)
EXPLORER_USERNAME=
EXPLORER_PASSWORD=

# Database connection pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_STATEMENT_TIMEOUT=5s
